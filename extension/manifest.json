{
  "manifest_version": 3,
  "name": "Riptag Set Manager",
  "version": "2.0.1",
  "description": "Connect Depop accounts to the Riptag Set Manager dashboard.",
  "permissions": ["cookies", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://www.depop.com/*",
    "https://*.depop.com/*",
    "http://localhost:3099/*",
    "https://riptag-rugpuller-production.up.railway.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "32": "icon.png", "128": "icon.png" }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{ "matches": ["https://www.depop.com/*"], "js": ["content.js"], "run_at": "document_idle" }],
  "icons": { "32": "icon.png", "128": "icon.png" }
}
